<Window x:Class="WorldCupStatistics.WPF.Views.PlayerDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:WorldCupStatistics.WPF.Localization"
        Title="{Binding [AppTitle], Source={x:Static loc:Loc.Instance}}"
        Width="320" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid x:Name="Root" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="40"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Grid.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.3"/>
                        <DoubleAnimation Storyboard.TargetName="SlideTransform" Storyboard.TargetProperty="Y"
                                         From="40" To="0" Duration="0:0:0.3"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Border x:Name="CaptainBorder" BorderThickness="0" CornerRadius="8" Margin="6">
            <Border.Effect>
                <DropShadowEffect x:Name="CaptainGlow" Color="Gold" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
            </Border.Effect>
            <StackPanel Margin="18">
            <Border Width="96" Height="96" HorizontalAlignment="Center" CornerRadius="48"
                    ClipToBounds="True" Background="#22000000" Margin="0,0,0,10">
                <Image x:Name="PlayerImage" Stretch="UniformToFill"/>
            </Border>
            <TextBlock x:Name="PlayerName" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding [ShirtNumber], Source={x:Static loc:Loc.Instance}}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="Number" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Text="{Binding [Position], Source={x:Static loc:Loc.Instance}}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="Position" FontWeight="Bold"/>
                <TextBlock Grid.Row="2" Text="{Binding [Captain], Source={x:Static loc:Loc.Instance}}"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="Captain" FontWeight="Bold"/>
                <TextBlock Grid.Row="3" Text="{Binding [GoalsInMatch], Source={x:Static loc:Loc.Instance}}"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="Goals" FontWeight="Bold"/>
                <TextBlock Grid.Row="4" Text="{Binding [YellowsInMatch], Source={x:Static loc:Loc.Instance}}"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="Yellows" FontWeight="Bold"/>
            </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>