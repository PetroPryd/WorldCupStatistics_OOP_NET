<Window x:Class="WorldCupStatistics.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:WorldCupStatistics.WPF.Localization"
        Title="{Binding [SettingsTitle], Source={x:Static loc:Loc.Instance}}"
        Width="380" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"
                       Text="{Binding [GenderLabel], Source={x:Static loc:Loc.Instance}}"/>
            <ComboBox Grid.Row="0" Grid.Column="1" Margin="8,4" ItemsSource="{Binding Genders}"
                      SelectedItem="{Binding SelectedGender}" DisplayMemberPath="Text"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"
                       Text="{Binding [LanguageLabel], Source={x:Static loc:Loc.Instance}}"/>
            <ComboBox Grid.Row="1" Grid.Column="1" Margin="8,4" ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}" DisplayMemberPath="Text"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"
                       Text="{Binding [DisplayModeLabel], Source={x:Static loc:Loc.Instance}}"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="8,4" ItemsSource="{Binding DisplayOptions}"
                      SelectedItem="{Binding SelectedDisplay}" DisplayMemberPath="Text"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button MinWidth="90" Margin="0,0,8,0" IsCancel="True"
                    Content="{Binding [Cancel], Source={x:Static loc:Loc.Instance}}"/>
            <Button MinWidth="90" IsDefault="True" Click="Confirm_Click"
                    Content="{Binding [Confirm], Source={x:Static loc:Loc.Instance}}"/>
        </StackPanel>
    </StackPanel>
</Window>
