<UserControl x:Class="WorldCupStatistics.WPF.Controls.PlayerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="72" Cursor="Hand">
    <Border Background="#CC000000" CornerRadius="6" Padding="3">
        <StackPanel>
            <Border Width="40" Height="40" HorizontalAlignment="Center"
                    CornerRadius="20" ClipToBounds="True" Background="#33FFFFFF">
                <Image x:Name="PlayerImage" Stretch="UniformToFill"/>
            </Border>
            <TextBlock x:Name="NumberText" Foreground="#FFD54F" FontWeight="Bold"
                       FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            <TextBlock x:Name="NameText" Foreground="White" FontSize="9"
                       TextAlignment="Center" TextWrapping="Wrap" MaxWidth="68"/>
        </StackPanel>
    </Border>
</UserControl>