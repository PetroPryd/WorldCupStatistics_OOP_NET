<UserControl x:Class="WorldCupStatistics.WPF.Controls.PlayerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="58" Cursor="Hand">
    <Border x:Name="CardBorder" Background="#CC000000" CornerRadius="5" Padding="2">
        <Border.Effect>
            <DropShadowEffect x:Name="CardGlow" Color="Gold" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
        </Border.Effect>
        <StackPanel>
            <Border x:Name="ImageHost" Width="30" Height="30" HorizontalAlignment="Center"
                    CornerRadius="15" ClipToBounds="True" Background="#33FFFFFF">
                <Image x:Name="PlayerImage" Stretch="UniformToFill"/>
            </Border>
            <TextBlock x:Name="NumberText" Foreground="#FFD54F" FontWeight="Bold"
                       FontSize="10" HorizontalAlignment="Center" Margin="0,1,0,0"/>
            <TextBlock x:Name="NameText" Foreground="White" FontSize="8"
                       TextAlignment="Center" TextWrapping="Wrap" MaxWidth="54"/>
        </StackPanel>
    </Border>
</UserControl>